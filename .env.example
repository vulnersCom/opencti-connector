# Переменные окружения для запуска контейнера (пример)
# НЕ храните реальные секреты в репозитории. Скопируйте этот файл в .env и заполните значения.

# OpenCTI (обязательные)
OPENCTI_URL=http://vulners.openctil:8080
OPENCTI_TOKEN=YOUR_OPENCTI_TOKEN_HERE

# Connector (опциональные, установлены значения по умолчанию)
CONNECTOR_ID=vulners-enrichment
CONNECTOR_NAME="Vulners Enrichment"
CONNECTOR_TYPE=INTERNAL_ENRICHMENT
# scope: comma-separated list
CONNECTOR_SCOPE="Vulnerability,Malware,Indicator"
CONNECTOR_AUTO=true
CONNECTOR_CONFIDENCE_LEVEL=85
CONNECTOR_LOG_LEVEL=info

# Vulners (обязательный: VULNERS_API_KEY)
VULNERS_API_KEY=YOUR_VULNERS_API_KEY_HERE
VULNERS_API_URL=http://vulners.vulners-main:8080
VULNERS_MAX_TLP=TLP:AMBER

# Пример использования (локально):
# cp .env.example .env
# docker build -t vulners-enrichment-connector .
# docker run --rm --env-file .env vulners-enrichment-connector

# Или передать переменные по одной:
# docker run --rm -e OPENCTI_URL=... -e OPENCTI_TOKEN=... -e VULNERS_API_KEY=... vulners-enrichment-connector
