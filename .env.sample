# OpenCTI (required)
OPENCTI_URL=http://localhost:8080
OPENCTI_TOKEN=ChangeMe

# Connector (CONNECTOR_ID is required; the rest are optional with sensible defaults)
CONNECTOR_ID=ChangeMe
CONNECTOR_TYPE=INTERNAL_ENRICHMENT
CONNECTOR_NAME=Vulners
CONNECTOR_SCOPE=Vulnerability
CONNECTOR_AUTO=true
CONNECTOR_LOG_LEVEL=error

# Vulners (VULNERS_API_KEY is required)
VULNERS_API_KEY=ChangeMe
VULNERS_API_BASE_URL=https://vulners.com
# Available values: TLP:CLEAR, TLP:WHITE, TLP:GREEN, TLP:AMBER, TLP:AMBER+STRICT, TLP:RED
VULNERS_MAX_TLP_LEVEL=TLP:AMBER
